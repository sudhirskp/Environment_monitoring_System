# ==================== FIREBASE WEB CONFIGURATION ====================
# Get these from Firebase Console: https://console.firebase.google.com
# Project Settings → Your apps → Web app config
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_DATABASE_URL=YOUR_FIREBASE_DATABASE_URL
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# ==================== ESP32 ARDUINO CONFIGURATION ====================
# WiFi Credentials (for check_the_base.cpp)
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# Firebase Credentials for ESP32
ESP32_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
ESP32_FIREBASE_DATABASE_URL=YOUR_FIREBASE_DATABASE_URL
ESP32_FIREBASE_USER_EMAIL=YOUR_FIREBASE_USER_EMAIL
ESP32_FIREBASE_USER_PASSWORD=YOUR_FIREBASE_USER_PASSWORD

# ==================== TELEGRAM CONFIGURATION ====================
# Get Bot Token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ==================== SERVICE ACCOUNT PATH ====================
# Path to Firebase service account JSON (only needed for Node.js backend)
# IMPORTANT: Never commit this file to GitHub!
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ==================== ALERT SETTINGS ====================
# Alert thresholds (must match settings in dashboard)
AQI_ALERT_THRESHOLD=300
GAS_ALERT_THRESHOLD=2500

# Alert cooldown in minutes (prevent alert spam)
ALERT_COOLDOWN_MINUTES=10

# ==================== NODE ENVIRONMENT ====================
# For development/production mode
NODE_ENV=development
