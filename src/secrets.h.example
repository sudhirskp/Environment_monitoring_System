// ==================== SECRETS.H TEMPLATE ====================
// Arduino/ESP32 Configuration File - SENSITIVE DATA
// 
// IMPORTANT: This file contains YOUR credentials
// DO NOT COMMIT THIS FILE TO GIT - It's in .gitignore
// 
// Setup Instructions:
// 1. Copy this file to secrets.h (in the src/ folder)
// 2. Fill in your actual credentials below
// 3. The C++ code will #include "secrets.h"
// 4. Never commit secrets.h to GitHub

// ==================== WiFi CREDENTIALS ====================
// Replace with your WiFi SSID (network name)
#define WIFI_SSID "YOUR_WIFI_SSID"

// Replace with your WiFi password
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// ==================== FIREBASE CREDENTIALS ====================
// Get from Firebase Console: https://console.firebase.google.com

// Firebase API Key
// Location: Project Settings → General → SDK setup and configuration
#define FIREBASE_API_KEY "past here"

// Firebase Realtime Database URL
// Location: Project Settings → General → Realtime Database
#define FIREBASE_DATABASE_URL "past Here"

// Firebase User Email
// Create a user in Firebase Authentication or use existing account
#define FIREBASE_USER_EMAIL "your_firebase_user_email@example.com"

// Firebase User Password
// Password for the Firebase user account
#define FIREBASE_USER_PASSWORD "YOUR_FIREBASE_USER_PASSWORD"

// ==================== OPTIONAL TELEGRAM INTEGRATION ====================
// Only needed if using Telegram alerts
// Get from @BotFather on Telegram

#define TELEGRAM_BOT_TOKEN "YOUR_TELEGRAM_BOT_TOKEN"
#define TELEGRAM_CHAT_ID "YOUR_TELEGRAM_CHAT_ID"

// ==================== DEFAULT THRESHOLDS ====================
// These can be overridden from Firebase dashboard
#define DEFAULT_AQI_THRESHOLD 300
#define DEFAULT_GAS_THRESHOLD 2500

// ==================== NOTES ====================
// - Keep this file in .gitignore
// - Never share this file or show it in version control
// - Regenerate credentials if accidentally exposed
// - Store in same directory as check_the_base.cpp
